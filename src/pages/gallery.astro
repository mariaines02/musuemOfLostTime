---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import GalleryItem from '../components/GalleryItem.astro';

// Gallery categories
const categories = [
  "All",
  "Computing",
  "Communication",
  "Audio",
  "Video",
  "Photography",
  "Gaming"
];

// Gallery items
const galleryItems = [
  {
    image: "https://images.pexels.com/photos/2166456/pexels-photo-2166456.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    title: "Rotary Telephone Collection",
    description: "1940s - 1980s communication devices",
    category: "Communication"
  },
  {
    image: "https://images.pexels.com/photos/163131/pexels-photo-163131.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    title: "Early Home Computers",
    description: "From Commodore 64 to early PCs",
    category: "Computing"
  },
  {
    image: "https://images.pexels.com/photos/374565/pexels-photo-374565.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    title: "Vintage Audio Equipment",
    description: "Turntables, tape decks, and stereo systems",
    category: "Audio"
  },
  {
    image: "https://images.pexels.com/photos/597077/pexels-photo-597077.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    title: "Camera Evolution",
    description: "From film to digital transition",
    category: "Photography"
  },
  {
    image: "https://images.pexels.com/photos/3017630/pexels-photo-3017630.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    title: "Arcade Game Machines",
    description: "Golden age of arcade gaming",
    category: "Gaming"
  },
  {
    image: "https://images.pexels.com/photos/4993044/pexels-photo-4993044.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    title: "VHS Collection",
    description: "Home video revolution",
    category: "Video"
  },
  {
    image: "https://images.pexels.com/photos/775414/pexels-photo-775414.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    title: "Portable Music Players",
    description: "From Walkman to iPod",
    category: "Audio"
  },
  {
    image: "https://images.pexels.com/photos/3760763/pexels-photo-3760763.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    title: "Mobile Phone Evolution",
    description: "Brick phones to early smartphones",
    category: "Communication"
  },
  {
    image: "https://images.pexels.com/photos/3825573/pexels-photo-3825573.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    title: "Calculators Through Time",
    description: "Mathematics machines evolution",
    category: "Computing"
  },
  {
    image: "https://images.pexels.com/photos/1532704/pexels-photo-1532704.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    title: "Video Game Consoles",
    description: "From Atari to PlayStation",
    category: "Gaming"
  },
  {
    image: "https://images.pexels.com/photos/821738/pexels-photo-821738.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    title: "Film Photography Equipment",
    description: "Cameras and darkroom tools",
    category: "Photography"
  },
  {
    image: "https://images.pexels.com/photos/594452/pexels-photo-594452.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    title: "Television History",
    description: "From CRT to flat screens",
    category: "Video"
  }
];
---

<Layout 
  title="Gallery"
  description="Browse our gallery of vintage technology and forgotten gadgets from the Museum of Lost Time collection."
>
  <Hero 
    title="Museum Gallery"
    subtitle="Explore our collection of vintage technology and forgotten gadgets"
    image="https://images.pexels.com/photos/6044266/pexels-photo-6044266.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2"
  />
  
  <!-- Gallery Categories -->
  <section class="py-8 bg-white dark:bg-dark-900 sticky top-16 z-40 shadow-sm">
    <div class="container mx-auto px-4">
      <div class="overflow-x-auto pb-3">
        <div class="flex space-x-2">
          {categories.map((category, index) => (
            <button 
              class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${index === 0 ? 'bg-primary-600 text-white' : 'bg-dark-100 dark:bg-dark-800 text-dark-600 dark:text-dark-300 hover:bg-primary-100 dark:hover:bg-primary-900/30 hover:text-primary-800 dark:hover:text-primary-300'}`}
              data-category={category === "All" ? "" : category}
            >
              {category}
            </button>
          ))}
        </div>
      </div>
    </div>
  </section>
  
  <!-- Gallery -->
  <section class="py-16 bg-white dark:bg-dark-900">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="gallery-grid">
        {galleryItems.map(item => (
          <div class="gallery-item" data-category={item.category}>
            <GalleryItem {...item} />
          </div>
        ))}
      </div>
      
      <div class="mt-16 text-center animate-on-scroll">
        <button 
          id="load-more"
          class="inline-flex items-center justify-center px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors"
        >
          Load More
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 ml-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
          </svg>
        </button>
      </div>
    </div>
  </section>
  
  <!-- Featured Collection -->
  <section class="py-24 bg-dark-50 dark:bg-dark-800/50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16 animate-on-scroll">
        <h2 class="font-display font-bold text-3xl md:text-4xl text-dark-900 dark:text-white mb-4">
          Featured Collection: Audio Evolution
        </h2>
        <p class="text-dark-600 dark:text-dark-300 max-w-3xl mx-auto">
          Experience the transformation of how we listened to music through the decades, from vinyl records to digital streaming.
        </p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div class="animate-on-scroll">
          <div class="relative h-full">
            <img 
              src="https://images.pexels.com/photos/7184626/pexels-photo-7184626.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2"
              alt="Record Collection" 
              class="w-full h-full object-cover rounded-lg shadow-lg"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-dark-900/80 via-dark-900/30 to-transparent flex flex-col justify-end p-6">
              <h3 class="font-display font-bold text-white text-2xl mb-2">The Vinyl Era</h3>
              <p class="text-white/90">
                From gramophones to turntables, the physical medium that defined music for generations.
              </p>
            </div>
          </div>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="animate-on-scroll">
            <div class="relative h-full">
              <img 
                src="https://images.pexels.com/photos/6076410/pexels-photo-6076410.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2"
                alt="Cassette Tapes" 
                class="w-full h-full object-cover rounded-lg shadow-lg"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-dark-900/80 via-dark-900/30 to-transparent flex flex-col justify-end p-4">
                <h3 class="font-display font-bold text-white text-lg mb-1">Cassette Culture</h3>
                <p class="text-white/90 text-sm">
                  The portable revolution and mixtape phenomenon.
                </p>
              </div>
            </div>
          </div>
          
          <div class="animate-on-scroll">
            <div class="relative h-full">
              <img 
                src="https://images.pexels.com/photos/812968/pexels-photo-812968.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2"
                alt="CD Collection" 
                class="w-full h-full object-cover rounded-lg shadow-lg"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-dark-900/80 via-dark-900/30 to-transparent flex flex-col justify-end p-4">
                <h3 class="font-display font-bold text-white text-lg mb-1">CD Revolution</h3>
                <p class="text-white/90 text-sm">
                  Digital audio arrives for mainstream consumers.
                </p>
              </div>
            </div>
          </div>
          
          <div class="animate-on-scroll">
            <div class="relative h-full">
              <img 
                src="https://images.pexels.com/photos/3951050/pexels-photo-3951050.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2"
                alt="Digital Music Players" 
                class="w-full h-full object-cover rounded-lg shadow-lg"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-dark-900/80 via-dark-900/30 to-transparent flex flex-col justify-end p-4">
                <h3 class="font-display font-bold text-white text-lg mb-1">MP3 Era</h3>
                <p class="text-white/90 text-sm">
                  "1000 songs in your pocket" changed everything.
                </p>
              </div>
            </div>
          </div>
          
          <div class="animate-on-scroll">
            <div class="relative h-full">
              <img 
                src="https://images.pexels.com/photos/7693953/pexels-photo-7693953.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2"
                alt="Streaming Music" 
                class="w-full h-full object-cover rounded-lg shadow-lg"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-dark-900/80 via-dark-900/30 to-transparent flex flex-col justify-end p-4">
                <h3 class="font-display font-bold text-white text-lg mb-1">Streaming Age</h3>
                <p class="text-white/90 text-sm">
                  The dematerialization of music ownership.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <div class="text-center mt-12 animate-on-scroll">
        <a 
          href="/exhibitions/audio-evolution" 
          class="inline-flex items-center justify-center px-6 py-3 border-2 border-primary-600 dark:border-primary-500 text-primary-600 dark:text-primary-400 hover:bg-primary-600 hover:text-white dark:hover:bg-primary-500 dark:hover:text-white font-medium rounded-lg transition-colors"
        >
          Explore Audio Collection
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 ml-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
  
  <!-- Virtual Tour Promo -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://images.pexels.com/photos/5935794/pexels-photo-5935794.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2" 
        alt="Museum interior" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-dark-900/70"></div>
    </div>
    
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-2xl mx-auto text-center animate-on-scroll">
        <h2 class="font-display font-bold text-3xl md:text-4xl text-white mb-6">
          Take Our Virtual Tour
        </h2>
        <p class="text-white/90 text-lg mb-8">
          Explore our museum from anywhere in the world with our immersive virtual tour. Get up close with artifacts and exhibits in 360° detail.
        </p>
        <a 
          href="/virtual-tour" 
          class="inline-flex items-center justify-center px-8 py-4 bg-white text-dark-900 hover:bg-dark-100 font-medium rounded-lg transition-colors"
        >
          Start Virtual Tour
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 ml-2">
            <path stroke-linecap="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Filter gallery by category
  const categoryButtons = document.querySelectorAll('[data-category]');
  const galleryItems = document.querySelectorAll('.gallery-item');
  const loadMoreButton = document.getElementById('load-more');
  
  // Initial display - show first 8 items
  const itemsPerPage = 8;
  let currentlyShown = itemsPerPage;
  let activeCategory = '';
  
  function updateGalleryDisplay() {
    let count = 0;
    
    galleryItems.forEach((item, index) => {
      const itemCategory = item.getAttribute('data-category');
      const matchesCategory = activeCategory === '' || itemCategory === activeCategory;
      
      if (matchesCategory) {
        count++;
        if (count <= currentlyShown) {
          item.style.display = 'block';
        } else {
          item.style.display = 'none';
        }
      } else {
        item.style.display = 'none';
      }
    });
    
    // Hide load more button if all matching items are shown
    const totalMatchingItems = [...galleryItems].filter(item => 
      activeCategory === '' || item.getAttribute('data-category') === activeCategory
    ).length;
    
    if (currentlyShown >= totalMatchingItems) {
      loadMoreButton.style.display = 'none';
    } else {
      loadMoreButton.style.display = 'inline-flex';
    }
  }
  
  // Initialize
  updateGalleryDisplay();
  
  // Category button click handlers
  categoryButtons.forEach(button => {
    button.addEventListener('click', () => {
      // Update active button styling
      categoryButtons.forEach(btn => {
        btn.classList.remove('bg-primary-600', 'text-white');
        btn.classList.add('bg-dark-100', 'dark:bg-dark-800', 'text-dark-600', 'dark:text-dark-300');
      });
      
      button.classList.remove('bg-dark-100', 'dark:bg-dark-800', 'text-dark-600', 'dark:text-dark-300');
      button.classList.add('bg-primary-600', 'text-white');
      
      // Filter gallery
      activeCategory = button.getAttribute('data-category');
      currentlyShown = itemsPerPage; // Reset to initial count when changing category
      updateGalleryDisplay();
    });
  });
  
  // Load more button
  loadMoreButton.addEventListener('click', () => {
    currentlyShown += itemsPerPage;
    updateGalleryDisplay();
  });
</script>