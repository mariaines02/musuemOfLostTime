---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';

const exhibits = [
  {
    title: "Early Mobile Phones",
    period: "1980s - 1990s",
    image: "https://images.pexels.com/photos/163007/phone-old-year-built-1955-163007.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    description: "From brick phones to flip phones, explore the evolution of mobile communication."
  },
  {
    title: "Personal Computing Revolution",
    period: "1970s - 1990s",
    image: "https://images.pexels.com/photos/2115257/pexels-photo-2115257.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    description: "Discover the machines that brought computing into our homes."
  },
  {
    title: "Audio Technology",
    period: "1960s - 2000s",
    image: "https://images.pexels.com/photos/6076410/pexels-photo-6076410.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    description: "From vinyl to digital, experience the evolution of personal audio."
  }
];

const interactiveElements = [
  {
    title: "Retro Gaming Station",
    description: "Play classic games on original hardware",
    image: "https://images.pexels.com/photos/3945683/pexels-photo-3945683.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2"
  },
  {
    title: "Communication Timeline",
    description: "Send a message through different eras of technology",
    image: "https://images.pexels.com/photos/163007/phone-old-year-built-1955-163007.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2"
  },
  {
    title: "Digital Revolution",
    description: "Interactive display of computing milestones",
    image: "https://images.pexels.com/photos/2115257/pexels-photo-2115257.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2"
  }
];
---

<Layout 
  title="The Tech Time Capsule"
  description="Explore our special exhibition showcasing rare and obsolete technologies from the 1970s to the early 2000s."
>
  <Hero 
    title="The Tech Time Capsule"
    subtitle="A journey through technological evolution from the 1970s to the early 2000s"
    image="https://images.pexels.com/photos/2587464/pexels-photo-2587464.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2"
  />
  
  <!-- Exhibition Overview -->
  <section class="py-16 bg-white dark:bg-dark-900">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center animate-on-scroll">
        <div class="inline-block px-4 py-2 bg-primary-100 dark:bg-primary-900/30 text-primary-800 dark:text-primary-300 rounded-full text-sm font-medium mb-6">
          June 1 - July 15, 2025
        </div>
        <h2 class="font-display font-bold text-3xl md:text-4xl text-dark-900 dark:text-white mb-6">
          Journey Through Time
        </h2>
        <p class="text-dark-600 dark:text-dark-300 text-lg mb-8">
          Step into our time capsule and explore the technologies that shaped our lives from the 1970s through the early 2000s. This exhibition showcases the rapid evolution of personal technology and its impact on society.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a 
            href="/tickets" 
            class="inline-flex items-center justify-center px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors"
          >
            Book Tickets
          </a>
          <a 
            href="#exhibits" 
            class="inline-flex items-center justify-center px-6 py-3 border-2 border-primary-600 dark:border-primary-500 text-primary-600 dark:text-primary-400 hover:bg-primary-600 hover:text-white dark:hover:bg-primary-500 dark:hover:text-white font-medium rounded-lg transition-colors"
          >
            View Exhibits
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Featured Exhibits -->
  <section id="exhibits" class="py-16 bg-dark-50 dark:bg-dark-800/50">
    <div class="container mx-auto px-4">
      <h2 class="font-display font-bold text-3xl text-dark-900 dark:text-white text-center mb-12 animate-on-scroll">
        Featured Exhibits
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {exhibits.map(exhibit => (
          <div class="bg-white dark:bg-dark-800 rounded-lg overflow-hidden shadow-md hover:shadow-lg transition-shadow animate-on-scroll">
            <img 
              src={exhibit.image} 
              alt={exhibit.title} 
              class="w-full h-48 object-cover"
            />
            <div class="p-6">
              <div class="text-primary-600 dark:text-primary-400 text-sm font-medium mb-2">
                {exhibit.period}
              </div>
              <h3 class="font-bold text-xl mb-2 text-dark-900 dark:text-white">
                {exhibit.title}
              </h3>
              <p class="text-dark-600 dark:text-dark-300">
                {exhibit.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Interactive Experiences -->
  <section class="py-16 bg-white dark:bg-dark-900">
    <div class="container mx-auto px-4">
      <h2 class="font-display font-bold text-3xl text-dark-900 dark:text-white text-center mb-12 animate-on-scroll">
        Interactive Experiences
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {interactiveElements.map(element => (
          <div class="group relative overflow-hidden rounded-lg shadow-md animate-on-scroll">
            <img 
              src={element.image} 
              alt={element.title} 
              class="w-full h-64 object-cover transition-transform duration-300 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-dark-900/80 via-dark-900/30 to-transparent flex flex-col justify-end p-6">
              <h3 class="font-bold text-white text-xl mb-2">{element.title}</h3>
              <p class="text-white/90">{element.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Exhibition Details -->
  <section class="py-16 bg-dark-50 dark:bg-dark-800/50">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-display font-bold text-3xl text-dark-900 dark:text-white text-center mb-12 animate-on-scroll">
          Exhibition Details
        </h2>
        
        <div class="bg-white dark:bg-dark-800 rounded-lg p-8 shadow-md animate-on-scroll">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <h3 class="font-bold text-xl mb-4 text-dark-900 dark:text-white">Visiting Information</h3>
              <ul class="space-y-3 text-dark-600 dark:text-dark-300">
                <li class="flex items-start">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-600 dark:text-primary-400 mr-3 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span>June 1 - July 15, 2025<br>Tuesday - Sunday, 10:00 AM - 6:00 PM</span>
                </li>
                <li class="flex items-start">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-600 dark:text-primary-400 mr-3 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span>Main Hall, Museum of Lost Time<br>123 Museum Street, Techville</span>
                </li>
              </ul>
            </div>
            
            <div>
              <h3 class="font-bold text-xl mb-4 text-dark-900 dark:text-white">Additional Information</h3>
              <ul class="space-y-3 text-dark-600 dark:text-dark-300">
                <li class="flex items-start">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-600 dark:text-primary-400 mr-3 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span>Guided tours available daily at 11:00 AM and 2:00 PM</span>
                </li>
                <li class="flex items-start">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-600 dark:text-primary-400 mr-3 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <span>Audio guides available in multiple languages</span>
                </li>
              </ul>
            </div>
          </div>
          
          <div class="mt-8 pt-8 border-t border-dark-100 dark:border-dark-700 text-center">
            <a 
              href="/tickets" 
              class="inline-flex items-center justify-center px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors"
            >
              Book Your Visit
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 ml-2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>