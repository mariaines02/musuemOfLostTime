---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import BlogCard from '../components/BlogCard.astro';

// Featured blog post
const featuredPost = {
  title: "The Last Days of the Telephone Booth",
  date: new Date("2025-04-15"),
  image: "image4.jpg",
  excerpt: "Once a common sight on every street corner, telephone booths have now become relics of a bygone era. This article examines their cultural significance and why they hold such a special place in our collective memory.",
  author: "Emma Richards",
  slug: "last-days-telephone-booth",
  featured: true
};

// Blog posts
const blogPosts = [
  {
    title: "Video Game Arcades: A Lost Social Experience",
    date: new Date("2025-04-02"),
    image: "/image6.jpg",
    excerpt: "Before online gaming, arcades were social hubs where gamers gathered to compete and connect. We explore this uniquely physical gaming culture that has largely disappeared from our digital world.",
    author: "Marcus Chen",
    slug: "video-game-arcades"
  },
  {
    title: "The Rise and Fall of the Cassette Tape",
    date: new Date("2025-03-28"),
    image: "/image7.jpg",
    excerpt: "How this simple magnetic storage device revolutionized portable music and created a mixtape culture that defined a generation, before being replaced by digital formats.",
    author: "Sophia Williams",
    slug: "rise-fall-cassette-tape"
  },
  {
    title: "Forgotten Office Technology: The Fax Machine",
    date: new Date("2025-03-15"),
    image: "/image8.jpg",
    excerpt: "Once an essential business tool, the fax machine has been largely replaced by email and digital communication. We look at its history and enduring legacy.",
    author: "Robert Johnson",
    slug: "forgotten-office-technology-fax-machine"
  },
  {
    title: "From Polaroid to Instagram: The Evolution of Instant Photography",
    date: new Date("2025-03-05"),
    image: "/image9.jpg",
    excerpt: "Exploring the connection between Polaroid's revolutionary instant cameras and today's digital photography filters and sharing culture.",
    author: "Diana Zhang",
    slug: "polaroid-to-instagram"
  },
  {
    title: "The CRT Television: When Screens Had Depth",
    date: new Date("2025-02-25"),
    image: "https://images.pexels.com/photos/2251206/pexels-photo-2251206.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2",
    excerpt: "A look back at cathode ray tube televisions that dominated homes for decades, their unique aesthetic, and why some enthusiasts still prefer them today.",
    author: "James Wilson",
    slug: "crt-television-depth"
  }
];

// Categories
const categories = [
  "Computing History",
  "Communication Devices",
  "Media Formats",
  "Gaming Technology",
  "Photography & Film",
  "Audio Equipment",
  "Office Technology",
  "Home Electronics"
];
---

<Layout 
  title="Blog"
  description="Explore articles and stories about vintage technology, forgotten gadgets, and the evolution of technology throughout history."
>
  <Hero 
    title="Museum Blog"
    subtitle="Stories, insights, and history about technology's fascinating past"
    image="/image3.jpg"
  />
  
  <!-- Featured Post -->
  <section class="py-16 bg-white dark:bg-dark-900">
    <div class="container mx-auto px-4">
      <h2 class="font-display font-bold text-3xl text-dark-900 dark:text-white text-center mb-12 animate-on-scroll">
        Featured Article
      </h2>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <img 
            src={featuredPost.image} 
            alt={featuredPost.title} 
            class="w-full h-auto rounded-lg shadow-lg object-cover"
          />
        </div>
        
        <div class="animate-on-scroll">
          <h3 class="font-display font-bold text-2xl md:text-3xl text-dark-900 dark:text-white mb-4">
            {featuredPost.title}
          </h3>
          <div class="text-primary-600 dark:text-primary-400 text-sm font-medium mb-4">
            {featuredPost.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })} • By {featuredPost.author}
          </div>
          <p class="text-dark-600 dark:text-dark-300 mb-8">
            {featuredPost.excerpt}
          </p>
          <a 
            href={`/blog/${featuredPost.slug}`}
            class="inline-flex items-center justify-center px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors"
          >
            Read Article
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 ml-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Latest Posts -->
  <section class="py-16 bg-dark-50 dark:bg-dark-800/50">
    <div class="container mx-auto px-4">
      <h2 class="font-display font-bold text-3xl text-dark-900 dark:text-white text-center mb-12 animate-on-scroll">
        Latest Articles
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {blogPosts.slice(0, 6).map(post => (
          <BlogCard {...post} />
        ))}
      </div>
      
      <div class="mt-12 text-center animate-on-scroll">
        <a 
          href="/blog/archive" 
          class="inline-flex items-center justify-center px-6 py-3 border-2 border-primary-600 dark:border-primary-500 text-primary-600 dark:text-primary-400 hover:bg-primary-600 hover:text-white dark:hover:bg-primary-500 dark:hover:text-white font-medium rounded-lg transition-colors"
        >
          View All Articles
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 ml-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
  
  <!-- Categories & Newsletter -->
  <section class="py-16 bg-white dark:bg-dark-900">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Categories -->
        <div class="animate-on-scroll">
          <h2 class="font-display font-bold text-2xl text-dark-900 dark:text-white mb-8">
            Categories
          </h2>
          
          <div class="flex flex-wrap gap-3">
            {categories.map(category => (
              <a 
                href={`/blog/category/${category.toLowerCase().replace(/\s+/g, '-')}`}
                class="inline-block px-4 py-2 rounded-full bg-dark-50 dark:bg-dark-700 text-dark-700 dark:text-dark-200 hover:bg-primary-100 dark:hover:bg-primary-900/30 hover:text-primary-800 dark:hover:text-primary-300 transition-colors text-sm font-medium"
              >
                {category}
              </a>
            ))}
          </div>
          
          <div class="mt-12">
            <h3 class="font-display font-bold text-xl text-dark-900 dark:text-white mb-4">
              Popular Tags
            </h3>
            
            <div class="flex flex-wrap gap-2">
              {['Vintage', 'Technology', 'Retro', 'Computing', 'Obsolete', 'Nostalgia', 'Digital History', 'Innovation'].map(tag => (
                <a 
                  href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`}
                  class="inline-block px-3 py-1 rounded-full bg-dark-100 dark:bg-dark-800 text-dark-600 dark:text-dark-300 hover:bg-primary-50 dark:hover:bg-primary-900/20 hover:text-primary-700 dark:hover:text-primary-400 transition-colors text-sm"
                >
                  #{tag}
                </a>
              ))}
            </div>
          </div>
        </div>
        
        <!-- Newsletter -->
        <div class="animate-on-scroll">
          <h2 class="font-display font-bold text-2xl text-dark-900 dark:text-white mb-6">
            Subscribe to Our Newsletter
          </h2>
          <p class="text-dark-600 dark:text-dark-300 mb-8">
            Get the latest museum news, blog posts, and event updates delivered directly to your inbox.
          </p>
          
          <form class="space-y-4">
            <div>
              <label for="name" class="block text-sm font-medium text-dark-700 dark:text-dark-300 mb-1">Name</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                class="w-full px-4 py-3 bg-white dark:bg-dark-800 border border-dark-200 dark:border-dark-700 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:focus:ring-primary-400 dark:focus:border-primary-400 transition-colors"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-dark-700 dark:text-dark-300 mb-1">Email</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                class="w-full px-4 py-3 bg-white dark:bg-dark-800 border border-dark-200 dark:border-dark-700 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:focus:ring-primary-400 dark:focus:border-primary-400 transition-colors"
                placeholder="Your email address"
              />
            </div>
            <div class="flex items-start">
              <input 
                type="checkbox" 
                id="consent" 
                name="consent" 
                class="mr-2 mt-1 h-4 w-4 text-primary-600 focus:ring-primary-500 border-dark-300 dark:border-dark-600 rounded"
              />
              <label for="consent" class="text-sm text-dark-600 dark:text-dark-400">
                I agree to receive email newsletters and updates from the Museum of Lost Time. See our <a href="/privacy" class="text-primary-600 dark:text-primary-400 hover:underline">Privacy Policy</a>.
              </label>
            </div>
            <button 
              type="submit" 
              class="w-full px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors"
            >
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>