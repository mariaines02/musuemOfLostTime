---
import { format } from 'date-fns';

interface Props {
  title: string;
  date: Date;
  image: string;
  excerpt: string;
  author: string;
  slug: string;
  featured?: boolean;
}

const { title, date, image, excerpt, author, slug, featured = false } = Astro.props;
const formattedDate = format(date, 'MMMM d, yyyy');

---

<article class={`overflow-hidden rounded-lg shadow-md hover:shadow-lg transition-shadow bg-white dark:bg-dark-800 ${featured ? 'md:col-span-2' : ''} animate-on-scroll`}>
  <a href={`/blog/${slug}`} class="block group">
    <div class="relative overflow-hidden">
      <img 
        src={image} 
        alt={title} 
        class={`w-full object-cover transition-transform duration-300 group-hover:scale-105 ${featured ? 'h-80' : 'h-56'}`}
      />
    </div>
    <div class="p-6">
      <div class="text-sm font-medium text-primary-600 dark:text-primary-400 mb-2">
        {formattedDate}
      </div>
      <h3 class="font-display font-bold text-xl mb-3 text-dark-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
        {title}
      </h3>
      <p class="text-dark-600 dark:text-dark-300 mb-4 line-clamp-3">
        {excerpt}
      </p>
      <div class="flex items-center text-dark-500 dark:text-dark-400 text-sm">
        <span>By {author}</span>
        <span class="inline-block mx-2">•</span>
        <span class="inline-flex items-center">
          Read more
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 ml-1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </span>
      </div>
    </div>
  </a>
</article>