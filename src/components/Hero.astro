---
interface Props {
  title: string;
  subtitle?: string;
  image: string;
  height?: 'small' | 'medium' | 'large';
}

const { 
  title, 
  subtitle, 
  image,
  height = 'medium'
} = Astro.props;

const heightClass = {
  small: 'min-h-[300px] md:min-h-[400px]',
  medium: 'min-h-[400px] md:min-h-[500px]',
  large: 'min-h-[500px] md:min-h-[600px]'
}[height];
---

<section class={`relative ${heightClass} flex items-center justify-center overflow-hidden`}>
  <div class="absolute inset-0 z-0">
    <img 
      src={image} 
      alt={title} 
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-dark-900/60"></div>
  </div>
  
  <div class="container mx-auto px-4 relative z-10 text-center">
    <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl text-white mb-4 animate-on-scroll">
      {title}
    </h1>
    {subtitle && (
      <p class="text-white/90 text-lg md:text-xl max-w-2xl mx-auto animate-on-scroll">
        {subtitle}
      </p>
    )}
  </div>
</section>