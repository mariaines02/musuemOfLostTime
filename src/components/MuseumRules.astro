---
const rules = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />
    </svg>`,
    title: 'No Flash Photography',
    description: 'Protects delicate items from light damage.',
    details: 'Regular photography without flash is permitted and encouraged. Share your visit with #MuseumOfLostTime'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
    </svg>`,
    title: 'Do Not Touch Artifacts',
    description: 'Use interactive zones only for hands-on experience.',
    details: 'Special interactive areas are provided where you can safely handle replicas and working models.'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z" />
    </svg>`,
    title: 'Keep Noise to a Minimum',
    description: 'Ensure a pleasant visit for all guests.',
    details: 'Maintain a quiet environment to allow everyone to enjoy their museum experience.'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z" />
    </svg>`,
    title: 'Food & Drink Prohibited',
    description: 'Help us keep the exhibits clean and preserved.',
    details: 'Our café area is available for refreshments. Water fountains are located throughout the museum.'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
    </svg>`,
    title: 'Respect Staff Instructions',
    description: 'Our staff is here to guide and help you.',
    details: 'Museum staff are knowledgeable experts ready to enhance your visit with insights and assistance.'
  }
];
---

<section class="py-16 bg-dark-50 dark:bg-dark-800/50">
  <div class="container mx-auto px-4">
    <h2 class="font-display font-bold text-3xl md:text-4xl text-dark-900 dark:text-white text-center mb-12 animate-on-scroll">
      Museum Guidelines
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {rules.map(rule => (
        <div class="bg-white dark:bg-dark-800 rounded-lg p-6 shadow-md hover:shadow-lg transition-all duration-300 group animate-on-scroll">
          <div class="text-primary-600 dark:text-primary-400 mb-4 transform group-hover:scale-110 transition-transform duration-300">
            <Fragment set:html={rule.icon} />
          </div>
          <h3 class="font-bold text-xl mb-2 text-dark-900 dark:text-white">{rule.title}</h3>
          <p class="text-dark-600 dark:text-dark-300 mb-4">{rule.description}</p>
          <p class="text-sm text-dark-500 dark:text-dark-400 border-t border-dark-100 dark:border-dark-700 pt-4">
            {rule.details}
          </p>
        </div>
      ))}
    </div>
    
    <div class="mt-12 max-w-2xl mx-auto text-center animate-on-scroll">
      <p class="text-dark-600 dark:text-dark-300">
        These guidelines help us preserve our artifacts and ensure an enjoyable experience for all visitors. Thank you for your cooperation.
      </p>
    </div>
  </div>
</section>