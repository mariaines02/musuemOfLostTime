---
const contactInfo = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
    </svg>`,
    title: 'Location',
    content: '123 Museum Street, Techville, NY 10001'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
    </svg>`,
    title: 'Hours',
    content: 'Tuesday - Sunday: 10am - 6pm<br>Closed on Mondays'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
    </svg>`,
    title: 'Contact',
    content: 'contact@museumoflosttime.com<br>+1 (555) 123-4567'
  }
];
---

<section class="py-16 bg-white dark:bg-dark-900">
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center animate-on-scroll">
      <h2 class="font-display font-bold text-3xl md:text-4xl text-dark-900 dark:text-white mb-4">
        Visit the Museum of Lost Time
      </h2>
      <p class="text-dark-600 dark:text-dark-300 mb-12 text-lg">
        Step back in time and explore our world of forgotten technology and everyday artifacts.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
      {contactInfo.map(item => (
        <div class="bg-dark-50 dark:bg-dark-800 p-6 rounded-lg text-center shadow-sm hover:shadow-md transition-shadow animate-on-scroll">
          <div class="text-primary-600 dark:text-primary-400 mx-auto mb-4">
            <Fragment set:html={item.icon} />
          </div>
          <h3 class="font-bold text-xl mb-2 text-dark-900 dark:text-white">{item.title}</h3>
          <p class="text-dark-600 dark:text-dark-300" set:html={item.content}></p>
        </div>
      ))}
    </div>
    
    <div class="mt-12 text-center animate-on-scroll">
      <a 
        href="/contact" 
        class="inline-flex items-center justify-center px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors"
      >
        Get Directions
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 ml-2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>